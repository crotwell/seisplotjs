{
  "compilerOptions": {
    "module": "es2020",
    "target": "es2020", // set to the *lowest* target you support
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": false,
    "strict": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "sourceMap": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "esModuleInterop": true,

    "types": ["jest", "jest-extended"]
  },
  "include": ["src"]
}

{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "preserve",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "bundler",
    "strict": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "skipLibCheck": false,
    "declaration": true,
    "declarationDir": "dist/dts_test",
    "outDir": "dist/dts_test",
    "rootDir": ".",
    "types": ["jest"]
  },
  "files": ["global.d.ts"
  ],
  "include": ["test", "testremotes"],
  "sourceMap": true
}
